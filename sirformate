    <!-- WhatsApp CTA -->
    <a class="cta" href="https://wa.me/?text=Maam%20meri%20mapping%20kariye%0A%0ACurrent%20Voter%20Details%202024%3A%0AAssembly%20No%3A%20138%20Kalyan%0AYadi%20No%3A%20160%0ASr%20No%3A%2093%0AVoter%20Card%20No%3A%20YFA9423120%0A%0A2002%20Voter%20Details%3A%0AName%3A%20Ismail%20Abdul%20Maniyar%0ARelation%3A%20Father%0AState%3A%20Maharashtra%0ADist%3A%20Thane%0AAssembly%3A%20Kalyan%0AYadi%20No%3A%20121%0ASr%20No%3A%2080" target="_blank">
